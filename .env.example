ADMIN_EMAIL=davidsha@cowinmagnet.com
ADMIN_DEFAULT_PASSWORD=change-this-local-password
ADMIN_JWT_SECRET=change-this-session-secret
CRON_SECRET=change-this-cron-secret
SITE_URL=https://cowinmagnet.cl
SITE_CONTENT_UPDATED_AT=2026-07-10T00:00:00.000Z

# Production database, same pattern as the main Cowinmagnet site.
DATABASE_URL=
CMS_TABLE_PREFIX=cowinmagnet_cl

# Inquiry notification email.
INQUIRY_TO_EMAIL=
INQUIRY_FROM_EMAIL=Cowinmagnet LATAM <davidsha@cowinmagnet.com>
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=true

# Google Search Console integration.
# Add the service account email as a user in Search Console, then set one of:
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# GOOGLE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json
GOOGLE_SEARCH_CONSOLE_SITE_URL=sc-domain:cowinmagnet.cl
GOOGLE_SEARCH_CONSOLE_SITEMAP_URL=https://cowinmagnet.cl/sitemap.xml
GOOGLE_SEARCH_CONSOLE_ENABLED=false
GOOGLE_SERVICE_ACCOUNT_CREDENTIALS_PATH=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_BASE64=
